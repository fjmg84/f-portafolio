---
import {
  IconArrowRight,
  IconGitHub,
  StreamlineGmail,
  FaLinkedin,
} from "../components/Icons";
import Layout from "../layouts/Layout.astro";

import {
  works,
  skills,
  jobs,
  contacts,
  about,
  downloadCV,
} from "../data/data.json";
import Tag from "../components/Tag.astro";
import Button from "../components/Button.astro";
import TitlePage from "../components/TitlePage.astro";
import Text from "../components/Text.astro";
import WorkTimeline from "../components/WorkTimeline.astro";

const IconMapper = {
  gmail: StreamlineGmail,
  github: IconGitHub,
  linkedin: FaLinkedin,
};

const categoryLabels: Record<string, string> = {
  core: "Core",
  "frameworks-libraries": "Frameworks/Libraries",
  stylized: "Stylized",
  "backend-tools": "Backend & Tools",
};

const categoryOrder = [
  "core",
  "frameworks-libraries",
  "stylized",
  "backend-tools",
];

const groupedSkills = skills.reduce<Record<string, typeof skills>>(
  (acc, skill) => {
    const key = skill.category || "other";
    if (!acc[key]) {
      acc[key] = [];
    }

    acc[key].push(skill);
    return acc;
  },
  {},
);

const orderedCategories = [
  ...categoryOrder.filter((category) => groupedSkills[category]?.length),
  ...Object.keys(groupedSkills)
    .filter((category) => !categoryOrder.includes(category))
    .sort((a, b) => a.localeCompare(b)),
];

const MARQUEE_COUNT = 20;
---

<Layout title="fjmg84">
  <main class="flex flex-col relative w-full">
    <section class="flex flex-col gap-5 justify-between items-center h-screen">
      <article
        class="flex flex-col-reverse md:flex-row-reverse h-full items-center justify-center gap-10"
      >
        <div class="flex flex-col gap-5 px-5 md:px-0">
          <h1 class="text-6xl font-extrabold">Hi, I'm Fidel Miranda</h1>
          <span class="text-purple-400 text-5xl"> frontend developer</span>
          <div class="flex gap-10 items-center flex-wrap">
            <Button
              target="_blank"
              href={downloadCV}
              variant
              rel="noopener noreferrer"
              >Download CV in pdf
              <div
                class="w-[12px] h-[12px] border-purple-400 border-2 rounded-full"
              >
              </div>
            </Button>
            <ul class="flex gap-6">
              {
                contacts.map((contact) => {
                  const icon = contact.image as keyof typeof IconMapper;
                  const Component = IconMapper[icon];
                  return (
                    <li>
                      <a
                        href={contact.url}
                        target="_blank"
                        aria-label={contact.label}
                      >
                        <div class="hover:bg-purple-400 shadow-2xl hover:shadow-violet-400 bg-purple-950 p-3 rounded-full transition-colors">
                          <Component width={20} height={20} />
                        </div>
                      </a>
                    </li>
                  );
                })
              }
            </ul>
          </div>
        </div>

        <picture class="w-[200px] h-[200px] flex relative">
          <img
            src="/logo.png"
            alt="logo"
            class="w-full h-full z-20"
            fetchpriority="high"
            height="500"
            width="auto"
            loading="lazy"
          />

          <div
            class="absolute transform w-[200px] h-[200px] z-10 bg-cyan-500/40 animate-glow-move rounded-full blur-xl"
          >
          </div>
          <div
            class="absolute transform w-[200px] h-[200px] z-10 bg-violet-900/40 animate-glow-move-delayed rounded-full blur-xl"
          >
          </div>
        </picture>
      </article>

      <article
        class="relative bottom-0 left-0 w-full h-[100px] flex overflow-x-hidden bg-purple-500"
      >
        <div class="animate-marquee flex whitespace-nowrap gap-4">
          {
            Array.from({ length: MARQUEE_COUNT }).map((_) => {
              return (
                <div class="text-white font-extralight text-6xl gap-4 flex items-center justify-center flex-shrink-0 flex-nowrap">
                  <p>Frontend Developer</p>
                  <IconArrowRight />
                </div>
              );
            })
          }
        </div>
        <div class="animate-marqueeCopy flex whitespace-nowrap gap-4">
          {
            Array.from({ length: MARQUEE_COUNT }).map((_) => {
              return (
                <div class="text-white font-extralight text-6xl gap-4 flex items-center justify-center flex-shrink-0 flex-nowrap">
                  <p>Frontend Developer</p>
                  <IconArrowRight />
                </div>
              );
            })
          }
        </div>
      </article>
    </section>

    <div
      class="px-5 py-36 md:px-0 w-full flex flex-col justify-center items-center"
    >
      <div
        class="flex flex-col gap-44 items-center w-full md:w-[80%] lg:w-[70%] xl:w-[60%]"
      >
        <section class="flex flex-col gap-5">
          <TitlePage title="About Me" />
          <Text>
            {about}
          </Text>
        </section>

        <section class="flex flex-col gap-5">
          <TitlePage title="Work Experience" />
          <WorkTimeline items={works} />
        </section>

        <section class="flex flex-col gap-5">
          <TitlePage title="Skills" />

          <Text
            >Expertise forged in building scalable, production-grade
            applications using modern industry standards.</Text
          >

          <div class="flex flex-col gap-8">
            {
              orderedCategories.map((category) => {
                const categorySkills = groupedSkills[category].sort((a, b) =>
                  a.name.localeCompare(b.name),
                );

                return (
                  <section class="skills-category">
                    <h3 class="skills-category__title">
                      {categoryLabels[category] || category}
                    </h3>

                    <ul class="flex flex-wrap gap-5 justify-start items-baseline">
                      {categorySkills.map((skill) => {
                        return (
                          <li
                            class="skill-pill text-white cursor-default rounded-lg"
                            style={`--skill-shadow: ${skill.bgColor || "#a855f7"};`}
                          >
                            <Tag
                              name={skill.name}
                              bgColor={skill.bgColor}
                              color={skill.color}
                            />
                          </li>
                        );
                      })}
                    </ul>
                  </section>
                );
              })
            }
          </div>
        </section>

        <section class="flex flex-col gap-5">
          <TitlePage title="Some Projects" />
          <ul class="flex flex-col gap-20">
            {
              jobs.map((job) => {
                return (
                  <li class="flex flex-col gap-10">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
                      <div class="flex w-full h-[400px] rounded-lg overflow-hidden">
                        {job.images.map((image) => {
                          return (
                            <img
                              src={image}
                              alt={image}
                              height="500"
                              width="auto"
                              loading="lazy"
                              class="w-0 flex-grow object-cover opacity-80 transition-all duration-300 hover:opacity-100 hover:cursor-crosshair hover:w-96"
                            />
                          );
                        })}
                      </div>

                      <div class="flex flex-col justify-between gap-5">
                        <div class="flex flex-col gap-5">
                          <p>{job.description}</p>

                          <div class="flex flex-wrap gap-2">
                            {job.tools
                              .sort((a, b) => a.localeCompare(b))
                              .map((tag) => {
                                const skill = skills.find((s) => s.id === tag);
                                return (
                                  <Tag
                                    name={skill?.name || tag}
                                    bgColor={skill?.bgColor}
                                    color={skill?.color}
                                  />
                                );
                              })}
                          </div>
                        </div>
                        <div class="flex flex-wrap gap-5">
                          {job.github && (
                            <Button
                              href={job.github}
                              target="_blank"
                              rel="noopener noreferrer"
                            >
                              github
                              <IconGitHub />
                            </Button>
                          )}
                          {job.site && (
                            <Button
                              href={job.site}
                              target="_blank"
                              rel="noopener noreferrer"
                              variant
                            >
                              {job.name} <IconArrowRight />
                            </Button>
                          )}
                        </div>
                      </div>
                    </div>
                  </li>
                );
              })
            }
          </ul>
        </section>

        <section class="flex flex-col gap-5">
          <ul class="flex gap-6">
            {
              contacts.map((contact) => {
                const icon = contact.image as keyof typeof IconMapper;
                const Component = IconMapper[icon];
                return (
                  <li>
                    <a
                      href={contact.url}
                      target="_blank"
                      aria-label={contact.label}
                    >
                      <div class="hover:bg-purple-400 shadow-2xl hover:shadow-violet-400 bg-purple-950 p-3 rounded-full transition-colors">
                        <Component width={20} height={20} />
                      </div>
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </section>
      </div>
    </div>
  </main>

  <style>
    .skills-category {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .skills-category__title {
      margin: 0;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #cfb3ff;
    }

    .skill-pill {
      transition:
        transform 200ms ease,
        box-shadow 200ms ease;
    }

    .skill-pill:hover {
      transform: scale(1.02);
      box-shadow: 0 10px 24px
        color-mix(in srgb, var(--skill-shadow) 42%, transparent);
    }

    .text-gradient {
      background-image: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-size: 400%;
      background-position: 0%;
    }

    .glow-purple {
      background: #a855f7;
      box-shadow:
        0 0 60px 30px #a855f7,
        0 0 100px 60px #7c3aed;
      opacity: 0.6;
    }

    .glow-cyan {
      background: #22d3ee;
      box-shadow:
        0 0 60px 30px #22d3ee,
        0 0 100px 60px #06b6d4;
      opacity: 0.6;
    }

    @keyframes glowMove {
      0%,
      100% {
        transform: translate(-10px, -10px) scale(1);
      }
      25% {
        transform: translate(10px, -10px) scale(1.1);
      }
      50% {
        transform: translate(10px, 10px) scale(1);
      }
      75% {
        transform: translate(-10px, 10px) scale(1.1);
      }
    }

    .animate-glow-move {
      animation: glowMove 4s ease-in-out infinite;
    }

    .animate-glow-move-delayed {
      animation: glowMove 4s ease-in-out infinite 2s;
    }
  </style>
</Layout>
